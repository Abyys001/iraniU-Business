# Copy to .env and fill in. Required for signing JWTs in production.
JWT_SECRET=change-this-to-a-long-random-string

# Used only when the super_admins table is empty: creates the first super admin on server start.
SUPER_ADMIN_EMAIL=you@example.com
SUPER_ADMIN_PASSWORD=your-secure-password

# Optional: Telegram alert on each successful super-admin login (/admin/login only).
# You can also set these from the super-admin UI: Admin → امنیت و ۲FA → پیکربندی تلگرام (stored in SQLite, overrides .env).
# Token: @BotFather. Chat ID: numeric id from @userinfobot. Send /start to your bot once first.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Required for "Kick out" inline button: same value as secret_token in setWebhook (HTTPS URL).
# Example: openssl rand -hex 24
# curl -F "url=https://YOUR_DOMAIN/api/telegram/webhook" -F "secret_token=YOUR_SECRET" https://api.telegram.org/bot<TOKEN>/setWebhook
TELEGRAM_WEBHOOK_SECRET=

# Post businesses to the public directory channel (Admin → «ارسال به کانال تلگرام»).
# Same bot as above; add the bot as admin in the channel with «Post messages».
# Channel: @YourChannelUsername or numeric id like -1001234567890
TELEGRAM_DIRECTORY_CHANNEL_ID=
# Public site URL for links and resolving /uploads/... images (HTTPS in production).
PUBLIC_SITE_URL=https://your-domain.example

# Optional SMTP for reservation emails (manager + customer).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
# SMTP_SECURE=1
EMAIL_FROM="Iraniu <no-reply@iraniu.uk>"

# Brute-force protection (manager + super-admin login): block IP after failed attempts in a time window.
# AUTH_BRUTE_MAX_FAILS=8
# AUTH_BRUTE_WINDOW_MS=900000
# AUTH_BRUTE_BLOCK_MS=1800000

# Behind nginx/caddy: set so X-Forwarded-For is used for client IP (brute-force + Telegram).
# TRUST_PROXY=1D
DDF